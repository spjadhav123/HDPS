{
  "outputDirectory": "dist-web",
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "mkdir -p dist-web && cp -R build/web/* dist-web/",
  "cleanUrls": true,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}