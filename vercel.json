{
  "outputDirectory": "build/web",
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "echo 'Skipping build command; using pre-built flutter files from build/web'",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}